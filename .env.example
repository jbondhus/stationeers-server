# Timezone (e.g. America/Chicago, Europe/London, UTC)
TZ=UTC

# Server identity -- used as the container name suffix and data subdirectory
SERVER_NAME=mars

# In-game display name shown in the server browser (defaults to SERVER_NAME if empty)
DISPLAY_NAME=

# Ports (UDP) -- each server instance needs unique ports
GAME_PORT=27016
UPDATE_PORT=27015

# World settings
# World types: Mars2, Lunar, Europa3, MimasHerschel, Vulcan, Venus
WORLD_TYPE=Mars2
WORLD_DIFFICULTY=Normal

# Save name (creates/loads saves/<SAVE_NAME> inside the server directory)
SAVE_NAME=default

# Server visibility and access
SERVER_VISIBLE=true
SERVER_PASSWORD=
SERVER_AUTH_SECRET=
MAX_PLAYERS=10

# Auto-save settings
AUTO_SAVE=true
SAVE_INTERVAL=300

# Pause when no players are connected
AUTO_PAUSE=true
